# Yinshi Configuration

# Google OAuth (optional -- leave empty to disable auth in dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/google

# GitHub OAuth (optional -- leave empty to disable GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback/github

# GitHub App (required for private GitHub repo imports)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_SLUG=

# Session signing key
SECRET_KEY=change-me-to-random-string

# Server-managed key encryption key for wrapping per-user DEKs.
# Generate 32+ random bytes and store as hex. ENCRYPTION_PEPPER remains as
# legacy fallback only for existing deployments.
KEY_ENCRYPTION_KEY=
KEY_ENCRYPTION_KEY_ID=local-v1
ENCRYPTION_PEPPER=

# Middle-ground storage encryption controls.
# Production should use TENANT_DB_ENCRYPTION=required with sqlcipher3/pysqlcipher3
# installed, and place USER_DATA_DIR on fscrypt/LUKS/encrypted-volume storage.
TENANT_DB_ENCRYPTION=auto
CONTROL_FIELD_ENCRYPTION=auto
USER_DATA_ENCRYPTION=disabled
REQUIRE_HTTPS=auto
HSTS_ENABLED=true

# Database path
DB_PATH=yinshi.db

# Host-side sidecar socket (used only when CONTAINER_ENABLED=false)
SIDECAR_SOCKET_PATH=/tmp/yinshi-sidecar.sock

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
# Per-user container isolation is the default tenant runtime.
# Set false only for explicit no-auth/dev/test host-side execution.
CONTAINER_ENABLED=true
CONTAINER_MOUNT_MODE=narrow

# Pi agent API key (used by sidecar)
ANTHROPIC_API_KEY=
