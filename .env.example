# Yinshi Configuration

# Google OAuth (optional -- leave empty to disable auth in dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/google

# GitHub OAuth (optional -- leave empty to disable GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback/github

# GitHub App (required for private GitHub repo imports)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_SLUG=

# Session signing key
SECRET_KEY=change-me-to-random-string

# Encryption pepper for wrapping per-user DEKs (64+ hex chars / 32+ bytes)
ENCRYPTION_PEPPER=

# Database path
DB_PATH=yinshi.db

# Host-side sidecar socket (used only when CONTAINER_ENABLED=false)
SIDECAR_SOCKET_PATH=/tmp/yinshi-sidecar.sock

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
# Per-user container isolation is the default tenant runtime.
# Set false only for explicit no-auth/dev/test host-side execution.
CONTAINER_ENABLED=true

# Pi agent API key (used by sidecar)
ANTHROPIC_API_KEY=
